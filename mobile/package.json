{
  "name": "deepchq-mobile",
  "version": "0.1.0",
  "private": true,
  "description": "Deepchq Android app (Capacitor wrapper)",
  "scripts": {
    "cap:sync": "cap sync android",
    "cap:open": "cap open android",
    "android:setup": "npm install && cap add android && cap sync android",
    "android:build": "cd android && ./gradlew assembleRelease",
    "android:bundle": "cd android && ./gradlew bundleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/app": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/splash-screen": "^7.0.0",
    "@capacitor/status-bar": "^7.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "typescript": "^5.7.3"
  },
  "capacitor": {
    "platforms": [
      "android"
    ]
  }
}
