# =============================================================================
# Deepchq — fill in your real values here
# =============================================================================
#
# 1. Copy this file:
#      cp config/env.values.template config/env.values
#
# 2. Edit config/env.values and paste your real keys (no quotes needed).
#
# 3. DO NOT commit config/env.values — it is in .gitignore.
#
# 4. Copy each value into Render (see docs/WHERE-TO-PUT-KEYS.md).
#    GitHub Actions only needs the keys listed in section B below.
#
# =============================================================================

# ── A) RENDER — Web service (deepchq) ─────────────────────────────────────────
# Dashboard: https://dashboard.render.com → your service → Environment

NEXT_PUBLIC_APP_URL=
DATABASE_URL=file:/app/data/deepchq.json
ALLOW_DEV_UNLOCK=false

SERPER_API_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_WEEKLY=
STRIPE_PRICE_PRO_QUARTERLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_BASIC_WEEKLY=
STRIPE_PRICE_BASIC_QUARTERLY=
STRIPE_PRICE_BASIC_YEARLY=

# Optional
OPENAI_API_KEY=
APPLE_CLIENT_ID=

# ── B) GITHUB ACTIONS — repo secrets only (not Render) ───────────────────────
# GitHub: repo → Settings → Secrets and variables → Actions → New repository secret

ADS_BASE_URL=

# ── C) MOBILE (optional) — file mobile/.env ─────────────────────────────────

CAPACITOR_SERVER_URL=
