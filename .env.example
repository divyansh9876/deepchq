# Copy to .env.local for local dev:  cp .env.example .env.local
# Full guide: docs/ENV-SETUP.md

# Required — public URL of the app (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Required — JSON database file path
DATABASE_URL=file:./data/deepchq.json

# Dev: unlock reports without Stripe. Production: false
ALLOW_DEV_UNLOCK=true

# Optional — real Google search results (https://serper.dev)
SERPER_API_KEY=

# Optional — Stripe subscriptions (see docs/ENV-SETUP.md)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_WEEKLY=
STRIPE_PRICE_PRO_QUARTERLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_BASIC_WEEKLY=
STRIPE_PRICE_BASIC_QUARTERLY=
STRIPE_PRICE_BASIC_YEARLY=

# Google Sign-In — https://console.cloud.google.com/apis/credentials
# Redirect URI: {NEXT_PUBLIC_APP_URL}/api/auth/oauth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Reserved / future
OPENAI_API_KEY=
APPLE_CLIENT_ID=
